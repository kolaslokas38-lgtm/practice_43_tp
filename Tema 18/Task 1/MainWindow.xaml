<Window x:Class="Task_1.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Электронный журнал" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Электронный журнал" FontSize="24" 
                   FontWeight="Bold" HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <ProgressBar Grid.Row="1" Height="10" IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Margin="0,0,0,10"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="5">
                <TextBlock Text="Студенты" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                <ListBox ItemsSource="{Binding Students}" 
                         SelectedItem="{Binding SelectedStudent}"
                         Height="300">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border BorderBrush="#2196F3" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,10,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Записать на курс" FontWeight="Bold" Margin="0,0,0,10" Foreground="#2196F3"/>

                        <TextBlock Grid.Row="1" Text="Курс:" Margin="0,5"/>
                        <ComboBox Grid.Row="2" ItemsSource="{Binding Courses}"
                                  SelectedItem="{Binding SelectedCourse}"
                                  Margin="0,0,0,10" Height="30"/>

                        <Button Grid.Row="3" Content="Зачислить" Command="{Binding EnrollStudentCommand}"
                                Background="#2196F3" Foreground="White" Height="35"/>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="5">
                <TextBlock Text="Оценки" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                <DataGrid ItemsSource="{Binding Enrollments}" 
                          SelectedItem="{Binding SelectedEnrollment}"
                          AutoGenerateColumns="False" Height="300">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Курс" Width="*" Binding="{Binding Course}"/>
                        <DataGridTextColumn Header="Оценка" Width="80" Binding="{Binding Grade}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border BorderBrush="#4CAF50" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,10,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Выставить оценку" FontWeight="Bold" Margin="0,0,0,10" Foreground="#4CAF50"/>

                        <TextBlock Grid.Row="1" Text="Оценка:" Margin="0,5"/>
                        <ComboBox Grid.Row="2" SelectedItem="{Binding NewGrade}" Margin="0,0,0,10" Height="30">
                            <ComboBoxItem Content="5"/>
                            <ComboBoxItem Content="4"/>
                            <ComboBoxItem Content="3"/>
                            <ComboBoxItem Content="2"/>
                        </ComboBox>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="Сохранить" Command="{Binding AddGradeCommand}"
                                    Background="#4CAF50" Foreground="White" Width="100" Height="35" Margin="0,0,10,0"/>
                            <Button Content="Удалить" Command="{Binding DeleteEnrollmentCommand}"
                                    Background="#F44336" Foreground="White" Width="100" Height="35"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>