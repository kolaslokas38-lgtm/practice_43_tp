@model ErrorViewModel
@{
    ViewData["Title"] = "Ошибка";
}

<h1 class="text-danger">Ошибка</h1>
<h2 class="text-danger">При обработке запроса произошла ошибка.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Идентификатор запроса:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Режим разработки</h3>
<p>
    В среде <strong>Development</strong> отображается больше сведений об ошибке.
</p>
<p>
    <strong>Не включайте режим Development на опубликованном сайте.</strong>
    Иначе пользователям могут быть видны конфиденциальные данные из исключений.
    Для отладки локально задайте переменную окружения <strong>ASPNETCORE_ENVIRONMENT</strong> = <strong>Development</strong> и перезапустите приложение.
</p>
