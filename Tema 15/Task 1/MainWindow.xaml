<Window x:Class="JournalApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:JournalApp.ViewModels"
        mc:Ignorable="d"
        Title="📚 Электронный журнал преподавателя" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:JournalViewModel/>
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="📖 Электронный журнал преподавателя" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="White"/>
                <TextBlock Text="Управление успеваемостью студентов" 
                           FontSize="12" 
                           Foreground="#BDC3C7" 
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <ProgressBar Grid.Row="1" 
                     Value="{Binding LoadingProgress}" 
                     Height="5" 
                     Margin="0,0,0,10"
                     Foreground="#3498DB">
            <ProgressBar.Style>
                <Style TargetType="ProgressBar">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ProgressBar.Style>
        </ProgressBar>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="8" Margin="0,0,10,0" Padding="10">
                <StackPanel>
                    <TextBlock Text="👨‍🎓 Студенты" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <ListBox ItemsSource="{Binding Students}"
                             SelectedItem="{Binding SelectedStudent}"
                             DisplayMemberPath="FullName"
                             Height="300"
                             Margin="0,0,0,10"/>

                    <Border Background="#ECF0F1" CornerRadius="5" Padding="10" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="📊 Средний балл выбранного студента" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SelectedStudentAverageGrade, StringFormat=F2}" 
                                       FontSize="24" 
                                       FontWeight="Bold"
                                       Foreground="#27AE60"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="8" Padding="10">
                <StackPanel>
                    <TextBlock Text="⭐ Управление оценками" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Text="Выберите предмет:" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Courses}"
                              SelectedItem="{Binding SelectedCourse}"
                              DisplayMemberPath="Name"
                              Margin="0,0,0,15"/>

                    <TextBlock Text="Введите оценку (1-5):" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" Text="{Binding NewGradeValue, UpdateSourceTrigger=PropertyChanged}"
                                 TextAlignment="Center"
                                 Margin="0,0,10,0"/>

                        <Button Grid.Column="1" 
                                Content="💾 Сохранить"
                                Command="{Binding SaveGradeCommand}"
                                Width="100"
                                Background="#27AE60"
                                Foreground="White"
                                Cursor="Hand"/>
                    </Grid>

                    <TextBlock Text="📋 История оценок" FontWeight="Bold" Margin="0,10,0,5"/>
                    <ListBox ItemsSource="{Binding Grades}" 
                             Height="250"
                             Margin="0,0,0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#ECF0F1" BorderThickness="0,0,0,1" Padding="5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Date, StringFormat=dd.MM.yyyy}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" 
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>

                                        <Button Grid.Column="2" 
                                                Content="✏️"
                                                Command="{Binding DataContext.EditGradeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Width="30"
                                                Background="#3498DB"
                                                Foreground="White"
                                                Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </Grid>

        <Button Grid.Row="3" 
                Content="🔄 Обновить данные"
                Command="{Binding LoadDataCommand}"
                Width="150"
                Height="35"
                Margin="0,15,0,0"
                HorizontalAlignment="Center"
                Background="#3498DB"
                Foreground="White"
                Cursor="Hand">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="IsEnabled" Value="True"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="IsEnabled" Value="False"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>