<Window x:Class="Task_1.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Электронный журнал" Height="733" Width="980"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#1E293B" CornerRadius="10" Padding="14">
            <DockPanel>
                <TextBlock Text="Электронный журнал" FontSize="22" FontWeight="Bold" Foreground="White"/>
                <TextBlock DockPanel.Dock="Right" Text="{Binding CurrentUsername}" Foreground="#CBD5E1" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,12">
            <TextBlock Text="Роль:" VerticalAlignment="Center"/>
            <TextBlock Text="Преподаватель" Margin="4,0,12,0"
                       Visibility="{Binding IsTeacher, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <TextBlock Text="Пользователь" Margin="4,0,12,0"
                       Visibility="{Binding IsStudent, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <Button Content="Студенты" Width="130" Margin="8,0,8,0"
                    Visibility="{Binding IsTeacher, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Click="OpenStudentsWindow_Click"/>
            <Button Content="Курсы" Width="130" Margin="0,0,8,0"
                    Visibility="{Binding IsTeacher, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Click="OpenCoursesWindow_Click"/>
            <Button Content="Выставление оценок" Width="180"
                    Visibility="{Binding IsTeacher, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Click="OpenGradeManagementWindow_Click"/>
            <Button Content="Обновить" Width="110" Margin="12,0,0,0" Click="Refresh_Click"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1.4*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="5">
                <TextBlock Text="Студенты" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                <ListBox ItemsSource="{Binding Students}" 
                         SelectedItem="{Binding SelectedStudent}"
                         Height="430">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <Grid Grid.Column="1" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Оценки по выбранному студенту" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding Enrollments}" 
                          AutoGenerateColumns="False" Height="180" Margin="0,0,0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Курс" Width="*" Binding="{Binding Course.Name}"/>
                        <DataGridTextColumn Header="Оценка" Width="80" Binding="{Binding Grade}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Прогресс студента" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Grid.Row="1" Text="{Binding AverageGradeDisplay, StringFormat=Средний балл: {0}}"/>
                        <TextBlock Grid.Row="2" Text="{Binding TotalCourses, StringFormat=Курсов с оценкой: {0}}"/>
                        <TextBlock Grid.Row="3" Text="{Binding BestGrade, StringFormat=Лучшая оценка: {0}}"/>
                        <TextBlock Grid.Row="4" Text="{Binding WorstGrade, StringFormat=Худшая оценка: {0}}"/>
                        <TextBlock Grid.Row="5" Text="{Binding ProgressStatus, StringFormat=Статус: {0}}" FontWeight="SemiBold" Margin="0,4,0,6"/>

                        <Grid Grid.Row="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Чат учитель ↔ пользователь" FontWeight="Bold" Margin="0,0,0,5"/>
                            <ComboBox Grid.Row="1" ItemsSource="{Binding Students}"
                                      SelectedItem="{Binding SelectedStudent}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,0,6"/>
                            <ListBox Grid.Row="2" ItemsSource="{Binding Messages}" Margin="0,0,0,6">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Display}" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <DockPanel Grid.Row="7" Margin="0,6,0,0">
                            <TextBox Text="{Binding NewMessageText, UpdateSourceTrigger=PropertyChanged}" 
                                     MinWidth="220" Margin="0,0,6,0"/>
                            <Button Content="Отправить" Width="95" Click="SendMessage_Click"/>
                        </DockPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>