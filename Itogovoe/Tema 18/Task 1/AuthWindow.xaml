<Window x:Class="Task_1.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в журнал"
        Height="420"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Border Margin="20" Padding="18" Background="#F7F9FC" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Авторизация" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>

            <StackPanel Grid.Row="1" Margin="0,18,0,0">
                <TextBlock Text="Логин"/>
                <TextBox x:Name="UsernameTextBox" Height="34"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,12,0,0">
                <TextBlock Text="Пароль"/>
                <PasswordBox x:Name="PasswordBox" Height="34"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,12,0,0">
                <TextBlock Text="Роль (для регистрации)"/>
                <ComboBox x:Name="RoleComboBox" Height="34" SelectedIndex="0">
                    <ComboBoxItem Content="Пользователь"/>
                    <ComboBoxItem Content="Преподаватель"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Войти" Width="110" Margin="0,0,8,0" Click="LoginButton_Click"/>
                <Button Content="Регистрация" Width="130" Click="RegisterButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

