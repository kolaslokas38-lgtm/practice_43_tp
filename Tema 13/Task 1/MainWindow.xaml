<Window x:Class="Task.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Task"
        Title="Электронный журнал" Height="550" Width="750"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddGradeCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditGradeCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteGradeCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- Меню -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Выход" InputGestureText="Alt+F4" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Студенты">
                <MenuItem Header="Список студентов" Click="Students_Click"/>
            </MenuItem>
            <MenuItem Header="_Оценки">
                <MenuItem Header="Добавить оценку" InputGestureText="Ctrl+N" 
                          Command="{Binding AddGradeCommand}"/>
                <MenuItem Header="Редактировать оценку" InputGestureText="Ctrl+E" 
                          Command="{Binding EditGradeCommand}"/>
                <Separator/>
                <MenuItem Header="Удалить оценку" InputGestureText="Del" 
                          Command="{Binding DeleteGradeCommand}"/>
            </MenuItem>
            <MenuItem Header="_Настройки">
                <MenuItem Header="Предметы" Click="Subjects_Click"/>
                <MenuItem Header="О программе" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Панель инструментов -->
        <ToolBar DockPanel.Dock="Top">
            <Button Content="➕ Добавить" Command="{Binding AddGradeCommand}"/>
            <Button Content="✏ Редактировать" Command="{Binding EditGradeCommand}"/>
            <Button Content="🗑 Удалить" Command="{Binding DeleteGradeCommand}"/>
        </ToolBar>

        <!-- Основное содержимое -->
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Электронный журнал" FontSize="20" 
                       FontWeight="Bold" HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Предмет:" VerticalAlignment="Center" 
                           FontSize="14" Margin="0,0,10,0"/>
                <ComboBox x:Name="cmbSubject" Width="200" 
                          SelectionChanged="CmbSubject_SelectionChanged"/>
            </StackPanel>

            <DataGrid x:Name="dgStudents" Grid.Row="2" 
                      AutoGenerateColumns="False" Margin="0,10"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      SelectedItem="{Binding SelectedStudent, Mode=TwoWay}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ФИО студента" Width="200" 
                                        Binding="{Binding Name}"/>
                    <DataGridTextColumn Header="Оценка" Width="80" 
                                        Binding="{Binding Grade}"/>
                    <DataGridTextColumn Header="Комментарий" Width="*" 
                                        Binding="{Binding Comment}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</Window>