<Window x:Class="Task.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Электронный журнал" Height="500" Width="700"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Электронный журнал" FontSize="20" 
                   FontWeight="Bold" HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Предмет:" VerticalAlignment="Center" 
                       FontSize="14" Margin="0,0,10,0"/>
            <ComboBox x:Name="cmbSubject" Width="200" 
                      SelectionChanged="CmbSubject_SelectionChanged"/>
        </StackPanel>

        <DataGrid x:Name="dgStudents" Grid.Row="2" 
                  AutoGenerateColumns="False" Margin="0,10"
                  CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ФИО студента" Width="200" 
                                    Binding="{Binding Name}"/>
                <DataGridTextColumn Header="Оценка" Width="80" 
                                    Binding="{Binding Grade}"/>
                <DataGridTextColumn Header="Комментарий" Width="*" 
                                    Binding="{Binding Comment}"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,10">
            <Button x:Name="btnAddGrade" Content="Добавить оценку" 
                    Width="120" Height="30" Click="BtnAddGrade_Click"/>
        </StackPanel>
    </Grid>
</Window>