<Window x:Class="JournalApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:JournalApp.ViewModels"
        mc:Ignorable="d"
        Title="📚 Электронный журнал преподавателя" 
        Height="500" Width="700"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate x:Key="StudentTemplate">
            <Border BorderBrush="#4A90E2" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Margin="5" 
                    Padding="10"
                    Background="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding Name}" 
                               FontSize="14" 
                               FontWeight="SemiBold" 
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Оц:" Margin="0,0,5,0"/>
                        <TextBox Text="{Binding Grade, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="40" 
                                 TextAlignment="Center"
                                 FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox IsChecked="{Binding IsPresent}" 
                                  Margin="0,0,5,0"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="Присутствует"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Ср.балл: " Foreground="Green" FontWeight="Bold"/>
                        <TextBlock Text="{Binding AverageScore, StringFormat=F2}" 
                                   Foreground="Green" 
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <ControlTemplate x:Key="ExcelButtonTemplate" TargetType="Button">
            <Border Background="#107C41" 
                    CornerRadius="6" 
                    Padding="12,8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#107C41"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0E5E32"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📊" FontSize="16" Foreground="White" Margin="0,0,8,0"/>
                    <TextBlock Text="Экспортировать в Excel" 
                               Foreground="White" 
                               FontWeight="SemiBold"
                               FontSize="13"/>
                </StackPanel>
            </Border>
        </ControlTemplate>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#4A90E2" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="📖 Электронный журнал преподавателя" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="White"/>
                <TextBlock Text="Введите оценки и отметьте посещаемость — средний балл пересчитается автоматически" 
                           FontSize="12" 
                           Foreground="LightGray" 
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="5,0,5,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="👨‍🎓 Студент" FontWeight="Bold" FontSize="13"/>
            <TextBlock Grid.Column="1" Text="⭐ Оценка" FontWeight="Bold" FontSize="13"/>
            <TextBlock Grid.Column="2" Text="✅ Посещаемость" FontWeight="Bold" FontSize="13"/>
            <TextBlock Grid.Column="3" Text="📊 Средний балл" FontWeight="Bold" FontSize="13"/>
        </Grid>

        <ListBox Grid.Row="2" 
                 ItemsSource="{Binding Students}" 
                 ItemTemplate="{StaticResource StudentTemplate}"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

        <Button Grid.Row="2" 
                Template="{StaticResource ExcelButtonTemplate}"
                Width="200" 
                Height="40"
                HorizontalAlignment="Right" 
                VerticalAlignment="Bottom"
                Margin="0,0,10,20"
                Click="ExportToExcel_Click"
                Cursor="Hand"/>
    </Grid>
</Window>