<Window x:Class="JournalApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в журнал" Height="300" Width="400"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20">
        <TextBlock Text="Электронный журнал" FontSize="20" 
                   FontWeight="Bold" HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <TextBlock Text="Логин:" Margin="0,5"/>
        <TextBox x:Name="LoginTextBox" Margin="0,5" Height="30"/>

        <TextBlock Text="Пароль:" Margin="0,10,0,5"/>
        <PasswordBox x:Name="PasswordBox" Margin="0,5" Height="30"/>

        <Button x:Name="LoginButton" Content="Войти" 
                Width="100" Height="35" Margin="0,20,0,0"
                HorizontalAlignment="Center"/>
    </StackPanel>
</Window>