@model IReadOnlyList<EveningMovies.Models.Movie>
@{
    ViewData["Title"] = "Список фильмов на вечер";
    var friend = ViewBag.FriendName as string ?? "";
}

<h1 class="mb-3">Список фильмов от друзей</h1>
<p class="lead">Рекомендации от: <strong>@friend</strong></p>

@if (Model.Count == 0)
{
    <p class="text-muted">Пока нет фильмов от этого друга. <a asp-action="Propose">Предложите фильм</a>.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Название</th>
                <th>Жанр</th>
                <th>Рекомендовал</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var m in Model)
        {
            <tr>
                <td>@m.Title</td>
                <td>@m.Genre</td>
                <td>@m.RecommendedBy</td>
            </tr>
        }
        </tbody>
    </table>
}

<p class="mt-3">
    <a class="btn btn-primary" asp-action="Propose">Предложить фильм</a>
    <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">На главную</a>
</p>
