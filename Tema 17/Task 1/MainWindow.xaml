<Window x:Class="JournalApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:JournalApp.ViewModels"
        Title="Электронный журнал" Height="800" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                            From="0" To="1" Duration="0:0:0.5"/>
        </Storyboard>

        <Storyboard x:Key="ShakeAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                            From="-5" To="5" Duration="0:0:0.05"
                            AutoReverse="True" RepeatBehavior="3x"/>
        </Storyboard>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="35"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                            To="0.8" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DeleteButton" TargetType="Button">
            <Setter Property="Background" Value="#F44336"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="35"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                            To="0.8" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:JournalViewModel/>
    </Window.DataContext>

    <Grid x:Name="MainGrid" Loaded="MainGrid_Loaded" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Электронный журнал" FontSize="24" 
                   FontWeight="Bold" HorizontalAlignment="Center"
                   Margin="0,0,0,10" Opacity="0">
            <TextBlock.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                            From="0" To="1" Duration="0:0:0.5"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </TextBlock.Triggers>
        </TextBlock>

        <TabControl Grid.Row="1" Margin="0,5">
            <TabItem Header="Журнал оценок">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Студенты" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                        <ListBox ItemsSource="{Binding Students}" 
                                 SelectedItem="{Binding SelectedStudent}"
                                 Height="300">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>

                                        <Border Grid.Column="1" Width="12" Height="12" CornerRadius="6"
                                                Background="Red" Margin="5,0,0,0"
                                                ToolTip="Низкая успеваемость!"
                                                Visibility="{Binding HasLowGrades, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Border.RenderTransform>
                                                <RotateTransform/>
                                            </Border.RenderTransform>
                                            <Border.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard Storyboard="{StaticResource ShakeAnimation}"/>
                                                </EventTrigger>
                                            </Border.Triggers>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Курсы" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                        <ListBox ItemsSource="{Binding Courses}" 
                                 SelectedItem="{Binding SelectedCourse}"
                                 Height="300">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="5">
                        <TextBlock Text="Оценки" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                        <ListView ItemsSource="{Binding Grades}" 
                                  SelectedItem="{Binding SelectedGrade}"
                                  Height="200">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="5" Padding="5" Margin="2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Value}" Value="5">
                                                        <Setter Property="Background" Value="LightGreen"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Value}" Value="4">
                                                        <Setter Property="Background" Value="LightBlue"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Value}" Value="3">
                                                        <Setter Property="Background" Value="LightYellow"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Value}" Value="2">
                                                        <Setter Property="Background" Value="LightCoral"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding Value}" FontSize="16" FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding CourseName}" Margin="5,0"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Comment}" Margin="5,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Border BorderBrush="#2196F3" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,10,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Добавить/Редактировать оценку" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="#2196F3"/>

                                <TextBlock Grid.Row="1" Text="Оценка:" Margin="0,5"/>
                                <ComboBox Grid.Row="2" SelectedItem="{Binding NewGradeValue}" Width="80"
                                          HorizontalAlignment="Left" Margin="0,0,0,10">
                                    <ComboBoxItem Content="5"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="2"/>
                                </ComboBox>

                                <TextBlock Grid.Row="3" Text="Комментарий:" Margin="0,5"/>
                                <TextBox Grid.Row="4" Text="{Binding NewGradeComment}" 
                                         Width="200" HorizontalAlignment="Left" Margin="0,0,0,10"/>

                                <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Content="Сохранить" Style="{StaticResource ActionButton}"
                                            Command="{Binding AddGradeCommand}"/>
                                    <Button Content="Удалить" Style="{StaticResource DeleteButton}"
                                            Command="{Binding DeleteGradeCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Прогресс студента">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Прогресс студента" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                    <TextBlock Grid.Row="1" Text="Выберите студента:" FontSize="14" Margin="0,5"/>
                    <ComboBox Grid.Row="2" ItemsSource="{Binding Students}" 
                              SelectedItem="{Binding SelectedStudent}"
                              DisplayMemberPath="Name" Margin="0,5" Height="30"/>

                    <Border Grid.Row="3" Background="#E3F2FD" CornerRadius="10" Padding="15" Margin="0,15">
                        <StackPanel>
                            <TextBlock Text="Средний балл" FontSize="14" Foreground="#1565C0"/>
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="#1565C0"
                                       Text="{Binding SelectedStudent.AverageGrade, StringFormat={}{0:F2}}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="4" Background="#E8F5E9" CornerRadius="10" Padding="15" Margin="0,5">
                        <StackPanel>
                            <TextBlock Text="Успеваемость" FontSize="14" Foreground="#2E7D32"/>
                            <Grid Margin="0,10,0,0">
                                <Rectangle Height="25" Fill="#C8E6C9" RadiusX="5" RadiusY="5"/>
                                <Rectangle x:Name="ProgressRect" Height="25" Fill="#4CAF50" 
                                           RadiusX="5" RadiusY="5" Width="0"/>
                            </Grid>
                            <TextBlock x:Name="PercentText" FontSize="16" FontWeight="Bold" 
                                       Foreground="#2E7D32" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,10,0,0" 
                                       FontSize="14" Foreground="#1B5E20"
                                       Text="{Binding StudentProgress}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="2" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готово"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>